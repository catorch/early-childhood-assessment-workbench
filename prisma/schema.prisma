generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  EDUCATOR
  ADMIN
}

enum AssessmentStatus {
  DRAFT
  UPLOADING
  PROCESSING
  READY_FOR_REVIEW
  IN_REVIEW
  FINALIZED
  FAILED
}

enum VideoAssetStatus {
  PENDING_UPLOAD
  AVAILABLE
  REPLACED
  DELETED
}

enum ProcessingRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum PrimaryCredit {
  PRESENT
  EMERGING
  NOT_OBSERVED
  NOT_APPLICABLE
}

enum DecisionOrigin {
  ACCEPTED
  OVERRIDDEN
  SCORED_INDEPENDENTLY
  DISMISSED
}

enum SupportEventType {
  VIDEO_ACCESSED
  DECISION_SAVED
  PROCESSING_RETRIED
  ACCESS_CHANGED
  ASSIGNMENT_CHANGED
  ROSTER_IMPORTED
  ASSESSMENT_FINALIZED
}

model User {
  id              String   @id @default(cuid())
  externalSubject String   @unique
  email           String?  @unique
  displayName     String?
  role            Role
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  provisionsCreated    AccessProvision[] @relation("ProvisionCreator")
  sessions             Session[]
  childAssignments     ChildAssignment[] @relation("EducatorAssignments")
  assignmentsCreated   ChildAssignment[] @relation("AssignmentCreator")
  assessments          Assessment[]      @relation("AssessmentEducator")
  finalizedAssessments Assessment[]      @relation("AssessmentFinalizer")
  uploadedVideos       VideoAsset[]      @relation("VideoUploader")
  videoAccessRecords   VideoAccessGrantRecord[]
  requestedRuns        ProcessingRun[]   @relation("RunRequester")
  reviewDecisions      ReviewDecision[]
}

model AccessProvision {
  id                    String    @id @default(cuid())
  externalSubject       String?   @unique
  exactEmail            String?
  intendedRole          Role
  providerEnrollmentRef String?
  provisionedById       String
  activatedAt           DateTime?
  deactivatedAt         DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  provisionedBy User @relation("ProvisionCreator", fields: [provisionedById], references: [id], onDelete: Restrict)

  @@index([exactEmail, deactivatedAt])
}

model Session {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model RateLimitBucket {
  scope        String   @db.VarChar(100)
  identityHash String   @db.VarChar(64)
  count        Int
  resetAt      DateTime
  updatedAt    DateTime @updatedAt

  @@id([scope, identityHash])
  @@index([resetAt])
}

model Child {
  id                String   @id @default(cuid())
  externalChildId   String   @unique
  ageMonths         Int
  approvedContext   Json?
  processingAllowed Boolean?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  assignments ChildAssignment[]
  assessments Assessment[]
}

model ChildAssignment {
  id          String    @id @default(cuid())
  educatorId  String
  childId     String
  startsAt    DateTime  @default(now())
  endsAt      DateTime?
  revokedAt   DateTime?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  educator  User  @relation("EducatorAssignments", fields: [educatorId], references: [id], onDelete: Restrict)
  child     Child @relation(fields: [childId], references: [id], onDelete: Restrict)
  createdBy User  @relation("AssignmentCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([educatorId, startsAt, endsAt, revokedAt])
  @@index([childId, startsAt, endsAt, revokedAt])
}

model Assessment {
  id              String           @id @default(cuid())
  childId         String
  educatorId      String
  observationDate DateTime
  contextSnapshot Json?
  contentCatalogVersion String       @default("help-2-provisional-2026-07")
  scoringContractVersion String      @default("help-scoring-v0")
  status          AssessmentStatus @default(DRAFT)
  finalizedById   String?
  finalizedAt     DateTime?
  revision        Int              @default(0)
  clientRequestId String?
  finalizationKey String?          @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  child          Child           @relation(fields: [childId], references: [id], onDelete: Restrict)
  educator       User            @relation("AssessmentEducator", fields: [educatorId], references: [id], onDelete: Restrict)
  finalizedBy    User?           @relation("AssessmentFinalizer", fields: [finalizedById], references: [id], onDelete: Restrict)
  videoAssets    VideoAsset[]
  processingRuns ProcessingRun[]
  videoAccessRecords VideoAccessGrantRecord[]

  @@index([educatorId, status, updatedAt])
  @@index([childId, observationDate])
  @@unique([educatorId, clientRequestId])
}

model VideoAsset {
  id               String           @id @default(cuid())
  assessmentId     String
  status           VideoAssetStatus @default(PENDING_UPLOAD)
  storageKey       String           @unique
  storageProvider  String           @default("local")
  storageBucket    String?
  storageGeneration String?
  originalFilename String?
  contentType      String?
  byteSize         BigInt?
  durationSeconds  Int?
  checksumSha256   String?
  checksumCrc32c   String?
  uploadedById     String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Restrict)
  uploadedBy User       @relation("VideoUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  accessRecords VideoAccessGrantRecord[]

  @@index([assessmentId, status])
}

model VideoAccessGrantRecord {
  id            String   @id @default(cuid())
  assessmentId  String
  videoAssetId  String
  viewerId      String
  purpose       String
  issuedAt      DateTime @default(now())
  expiresAt     DateTime

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Restrict)
  videoAsset VideoAsset @relation(fields: [videoAssetId], references: [id], onDelete: Restrict)
  viewer     User       @relation(fields: [viewerId], references: [id], onDelete: Restrict)

  @@index([assessmentId, viewerId, issuedAt])
  @@index([videoAssetId, expiresAt])
}

model ProcessingRun {
  id                            String              @id @default(cuid())
  assessmentId                  String
  attempt                       Int
  status                        ProcessingRunStatus @default(QUEUED)
  externalJobId                 String?             @unique
  scoringConfigurationReference String?
  safeErrorCode                 String?
  retryOfRunId                  String?
  requestedById                 String
  submittedAt                   DateTime?
  startedAt                     DateTime?
  completedAt                   DateTime?
  triggerEventId                String?             @unique
  triggerObjectGeneration       String?
  deliveryCount                 Int                 @default(0)
  lastDispatchedAt              DateTime?
  createdAt                     DateTime            @default(now())
  updatedAt                     DateTime            @updatedAt

  assessment  Assessment        @relation(fields: [assessmentId], references: [id], onDelete: Restrict)
  requestedBy User              @relation("RunRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  suggestions SkillSuggestion[]
  retryOf      ProcessingRun?   @relation("ProcessingRetries", fields: [retryOfRunId], references: [id], onDelete: Restrict)
  retries      ProcessingRun[]  @relation("ProcessingRetries")

  @@unique([assessmentId, attempt])
  @@index([assessmentId, status])
}

model SkillSuggestion {
  id                String         @id @default(cuid())
  processingRunId   String
  sourceSkillId     String
  skillCode         String
  skillName         String
  domain            String
  strand            String?
  draftCredit       PrimaryCredit?
  confidence        Float?
  uncertaintyReason String?
  evidence          Json
  rationale         String?
  sourceOrder       Int
  createdAt         DateTime       @default(now())

  processingRun ProcessingRun   @relation(fields: [processingRunId], references: [id], onDelete: Restrict)
  decision      ReviewDecision?

  @@unique([processingRunId, sourceSkillId])
  @@unique([processingRunId, sourceOrder])
}

model ReviewDecision {
  id           String         @id @default(cuid())
  suggestionId String         @unique
  educatorId   String
  origin       DecisionOrigin
  finalCredit  PrimaryCredit?
  dismissed    Boolean        @default(false)
  note         String?
  revision     Int            @default(1)
  decidedAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  suggestion SkillSuggestion @relation(fields: [suggestionId], references: [id], onDelete: Restrict)
  educator   User            @relation(fields: [educatorId], references: [id], onDelete: Restrict)

  @@index([educatorId, decidedAt])
}

model SupportEvent {
  id           String           @id
  type         SupportEventType
  actorId      String
  occurredAt   DateTime         @default(now())
  assessmentId String?
  subjectId    String?
  referenceId  String?

  @@index([actorId, occurredAt])
  @@index([assessmentId, occurredAt])
}
