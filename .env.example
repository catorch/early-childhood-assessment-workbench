# Pooled Neon connection used by the runtime Prisma driver adapter.
DATABASE_URL="postgresql://user:password@host-pooler.example/neondb?sslmode=require"

# Direct Neon connection used only by Prisma schema and migration commands.
DIRECT_URL="postgresql://user:password@host.example/neondb?sslmode=require"

# Local two-process development (`pnpm dev:stack`) defaults to local state,
# local video, the HTTP processor boundary, fake scoring, and sandbox identity.
# HELP_REVIEW_STATE_ADAPTER="local"
# HELP_REVIEW_VIDEO_ADAPTER="local"
# HELP_REVIEW_PROCESSING_ADAPTER="http"
# HELP_REVIEW_PROCESSOR_URL="http://127.0.0.1:8081"
# HELP_REVIEW_SCORING_ADAPTER="fake"
# HELP_REVIEW_FAKE_SCORING_SCENARIO="accepted"
# HELP_REVIEW_IDENTITY_ADAPTER="sandbox"
# HELP_REVIEW_WORKER_SECRET="optional-shared-local-processor-secret"

# Select these for the sanitized Google Cloud deployment. Terraform injects
# secrets from Secret Manager and sets non-secret values on both services.
# HELP_REVIEW_STATE_ADAPTER="neon"
# HELP_REVIEW_VIDEO_ADAPTER="gcs"
# HELP_REVIEW_PROCESSING_ADAPTER="gcs-event"
# HELP_REVIEW_SCORING_ADAPTER="vertex"
# HELP_REVIEW_IDENTITY_ADAPTER="sandbox"
# HELP_REVIEW_SEED_SANITIZED_DATA="true"
# GCS_VIDEO_BUCKET="project-help-review-videos"
# GCS_PROCESSING_REQUEST_PREFIX="processing-requests/"
# GOOGLE_CLOUD_PROJECT="project-id"
# VERTEX_AI_LOCATION="us-central1"
# VERTEX_AI_MODEL="gemini-2.5-flash"
# HELP_REVIEW_MAX_PROCESSING_DELIVERIES="5"
# HELP_REVIEW_SESSION_SECRET="generate-a-different-32-byte-secret"
# HELP_REVIEW_PLAYBACK_GRANT_SECRET="generate-a-third-32-byte-secret"
# HELP_REVIEW_UPLOAD_GRANT_SECRET="generate-a-fourth-32-byte-secret"
# HELP_REVIEW_WORKER_SECRET="generate-a-fifth-32-byte-secret"

# This acknowledges sandbox identity and fake scoring. It does not approve real child data.
# HELP_REVIEW_SANITIZED_PRODUCTION_ACK="true"

# Legacy Gemini Developer API emulator. The GCP path uses Vertex ADC instead
# and does not require an API key or Gemini Files upload.
# HELP_REVIEW_SCORING_ADAPTER="gemini"
# GEMINI_API_KEY="..."
# GEMINI_MODEL="gemini-2.5-flash"

# Real child data stays fail-closed without an accepted approval record and
# non-sandbox identity/scoring adapters.
# HELP_REVIEW_REAL_DATA_ENABLED="false"
# HELP_REVIEW_REAL_DATA_APPROVAL_ID="accepted-decision-register-reference"
