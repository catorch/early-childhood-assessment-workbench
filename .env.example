# Pooled Neon connection used by the runtime Prisma driver adapter.
DATABASE_URL="postgresql://user:password@host-pooler.example/neondb?sslmode=require"

# Direct Neon connection used only by Prisma schema and migration commands.
DIRECT_URL="postgresql://user:password@host.example/neondb?sslmode=require"

