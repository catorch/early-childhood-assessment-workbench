{
  "name": "help-review-pilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "dev:processor": "tsx watch processor/server.ts",
    "dev:stack": "concurrently -k -n web,processor \"HELP_REVIEW_PROCESSING_ADAPTER=http HELP_REVIEW_PROCESSOR_URL=http://127.0.0.1:8081 next dev\" \"HELP_REVIEW_PROCESSOR_PORT=8081 tsx watch processor/server.ts\"",
    "build": "next build",
    "build:processor": "esbuild processor/server.ts --bundle --platform=node --target=node24 --format=esm --packages=external --outfile=dist-processor/server.mjs",
    "start": "next start",
    "start:processor": "tsx processor/server.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:e2e": "playwright test --grep-invert '@visual|@a11y'",
    "test:a11y": "playwright test --grep @a11y",
    "test:visual": "playwright test --grep @visual",
    "test:visual:update": "playwright test --grep @visual --update-snapshots",
    "roster:import": "tsx scripts/import-roster.ts",
    "admin:bootstrap": "tsx scripts/bootstrap-admin.ts",
    "catalog:build-reference": "node scripts/build-reference-skills-catalog.mjs",
    "catalog:import-help": "tsx scripts/import-help-workbook.ts",
    "catalog:validate": "tsx scripts/validate-help-catalog.ts",
    "db:recovery-drill": "tsx scripts/database-recovery-drill.ts",
    "db:rate-limit-drill": "tsx scripts/shared-rate-limit-drill.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:validate": "prisma validate",
    "db:status": "prisma migrate status"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.21.0",
    "@google/genai": "^2.11.0",
    "@prisma/adapter-neon": "7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "@vercel/blob": "^2.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^7.0.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.6",
    "pdf-lib": "^1.17.1",
    "pg": "^8.22.0",
    "radix-ui": "^1.6.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "^24.10.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.2.6",
    "exceljs": "^4.4.0",
    "playwright": "^1.61.1",
    "prisma": "7.8.0",
    "shadcn": "4.13.0",
    "tailwindcss": "4.3.0",
    "tsx": "^4.23.1",
    "typescript": "6.0.3",
    "vitest": "^4.0.13"
  },
  "packageManager": "pnpm@10.26.0"
}
